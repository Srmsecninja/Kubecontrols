# Terraform Variables Template
# Copy this file to terraform.tfvars and fill in with your actual values
# IMPORTANT: terraform.tfvars should NEVER be committed to version control

# ARN of the IAM role used by the EKS cluster
cluster_role_arn = "arn:aws:iam::ACCOUNT_ID:role/YOUR_EKS_ROLE_NAME"

# ARN of the IAM role used by the EKS worker nodes
node_role_arn = "arn:aws:iam::ACCOUNT_ID:role/YOUR_NODE_ROLE_NAME"

# List of subnet IDs to be used by the EKS cluster
# Get these from your VPC configuration
subnet_ids = [
  "subnet-xxxxxxxxx",
  "subnet-yyyyyyyyy",
]

# ID of the VPC to be used by the EKS cluster
vpc_id = "vpc-xxxxxxxxx"

# ARN of the assume role for Terraform execution
assume_role_arn = "arn:aws:iam::ACCOUNT_ID:role/YOUR_TERRAFORM_ROLE"

# ARN of the KMS key for encrypting Kubernetes secrets
kms_key_id = "arn:aws:kms:us-east-1:ACCOUNT_ID:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# AMI ID for worker nodes (optional)
ami_id = "ami-xxxxxxxxx"

# Kubernetes version for the EKS cluster
eks_cluster_version = "1.29"

# EKS node group disk size in GB
eks_node_group_disk_size = 30

# Desired number of nodes in the node group
eks_node_group_desired_size = 2

# Maximum number of nodes for auto-scaling
eks_node_group_max_size = 4

# Minimum number of nodes for auto-scaling
eks_node_group_min_size = 1

# Name of the EKS cluster
cluster_name = "my-cluster-name"
